module Crypto {


    // Constants


    pub const AES_BLOCK_SIZE:   uint32 = 16u32;
    pub const AES_128_KEY_SIZE: uint32 = 16u32;
    pub const AES_256_KEY_SIZE: uint32 = 32u32;


    // Structures


    pub struct AesContext {
        pub roundKeys: uint8[240];  // enough for AES-256 (60 words × 4 bytes)
        pub rounds:    uint32;      // 10 for AES-128, 14 for AES-256
    }


    // Internal — GF(2^8) multiply


    func AesXtime(b: uint8) -> uint8 {
        // Multiply by 2 in GF(2^8) with reduction polynomial x^8+x^4+x^3+x+1
        let shifted = b << 1u8;
        let mask    = ((b >> 7u8) & 0x01u8) * 0x1Bu8;
        return shifted ^ mask;
    }

    func AesMul(a: uint8, b: uint8) -> uint8 {
        // Multiply a by b in GF(2^8) using double-and-add
        var result: uint8 = 0x00u8;
        var aa:     uint8 = a;
        var bb:     uint8 = b;
        while bb != 0x00u8 {
            if (bb & 0x01u8) != 0x00u8 {
                result = result ^ aa;
            }
            aa = AesXtime(aa);
            bb = bb >> 1u8;
        }
        return result;
    }


    // Internal — S-box tables


    func AesSboxAt(i: uint8) -> uint8 {
        // AES forward S-box, row-by-row (256 entries)
        var S: uint8[256];
        S[0]   = 0x63u8; S[1]   = 0x7cu8; S[2]   = 0x77u8; S[3]   = 0x7bu8;
