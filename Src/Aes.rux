    func AesSboxInvAt(i: uint8) -> uint8 {
        // AES inverse S-box
        var S: uint8[256];
        S[0]   = 0x52u8; S[1]   = 0x09u8; S[2]   = 0x6au8; S[3]   = 0xd5u8;
