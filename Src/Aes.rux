    // Internal — key expansion


    func AesSubWord(w: uint32) -> uint32 {
        return (AesSboxAt(((w >> 24u32) & 0xFFu32) as uint8) as uint32 << 24u32)
             | (AesSboxAt(((w >> 16u32) & 0xFFu32) as uint8) as uint32 << 16u32)
             | (AesSboxAt(((w >>  8u32) & 0xFFu32) as uint8) as uint32 <<  8u32)
             | (AesSboxAt(( w           & 0xFFu32) as uint8) as uint32);
    }

    func AesRotWord(w: uint32) -> uint32 {
        return (w << 8u32) | (w >> 24u32);
    }

    func AesExpandKey(ctx: *AesContext, key: *const uint8, keyBits: uint32) {
        let nk = keyBits / 32u32;   // 4 for AES-128, 8 for AES-256
        let nr = nk + 6u32;         // 10 for AES-128, 14 for AES-256
        ctx.rounds = nr;

        // Total words needed: (rounds+1) * 4
        let totalWords = (nr + 1u32) * 4u32;

        // Rcon table (first 11 values, index starts at 1)
        var Rcon: uint32[11];
        Rcon[0]  = 0x00000000u32;
        Rcon[1]  = 0x01000000u32;
        Rcon[2]  = 0x02000000u32;
        Rcon[3]  = 0x04000000u32;
        Rcon[4]  = 0x08000000u32;
        Rcon[5]  = 0x10000000u32;
        Rcon[6]  = 0x20000000u32;
        Rcon[7]  = 0x40000000u32;
        Rcon[8]  = 0x80000000u32;
        Rcon[9]  = 0x1b000000u32;
        Rcon[10] = 0x36000000u32;

        var W: uint32[60];

        // Load raw key words
        var i: uint32 = 0u32;
        while i < nk {
            let j = i * 4u32;
            W[i] = (key[j as uint]           as uint32 << 24u32)
                 | (key[(j + 1u32) as uint]  as uint32 << 16u32)
                 | (key[(j + 2u32) as uint]  as uint32 <<  8u32)
                 | (key[(j + 3u32) as uint]  as uint32);
            i = i + 1u32;
        }

        // Expand
        i = nk;
        while i < totalWords {
            var temp = W[i - 1u32];
            if (i % nk) == 0u32 {
                temp = AesSubWord(AesRotWord(temp)) ^ Rcon[i / nk];
            } else if nk > 6u32 && (i % nk) == 4u32 {
                temp = AesSubWord(temp);
            }
            W[i] = W[i - nk] ^ temp;
            i = i + 1u32;
        }

        // Store round keys as bytes into ctx.roundKeys
        i = 0u32;
        while i < totalWords {
            let base = i * 4u32;
            ctx.roundKeys[base]       = ((W[i] >> 24u32) & 0xFFu32) as uint8;
            ctx.roundKeys[base + 1u32] = ((W[i] >> 16u32) & 0xFFu32) as uint8;
            ctx.roundKeys[base + 2u32] = ((W[i] >>  8u32) & 0xFFu32) as uint8;
            ctx.roundKeys[base + 3u32] = ( W[i]           & 0xFFu32) as uint8;
            i = i + 1u32;
        }
    }


    // Internal — single block encrypt/decrypt


    func AesAddRoundKey(state: *uint8, rk: *const uint8) {
        var i: uint32 = 0u32;
        while i < 16u32 {
            state[i] = state[i] ^ rk[i];
            i = i + 1u32;
        }
    }

    func AesSubBytes(state: *uint8) {
        var i: uint32 = 0u32;
        while i < 16u32 {
            state[i] = AesSboxAt(state[i]);
            i = i + 1u32;
        }
    }

    func AesSubBytesInv(state: *uint8) {
        var i: uint32 = 0u32;
        while i < 16u32 {
            state[i] = AesSboxInvAt(state[i]);
            i = i + 1u32;
        }
    }

    func AesShiftRows(state: *uint8) {
        // Row 1: shift left by 1
        let t1 = state[1];
        state[1] = state[5]; state[5] = state[9]; state[9] = state[13]; state[13] = t1;
        // Row 2: shift left by 2
        let t2a = state[2]; let t2b = state[6];
        state[2] = state[10]; state[6] = state[14]; state[10] = t2a; state[14] = t2b;
        // Row 3: shift left by 3 (= shift right by 1)
        let t3 = state[15];
        state[15] = state[11]; state[11] = state[7]; state[7] = state[3]; state[3] = t3;
    }

    func AesShiftRowsInv(state: *uint8) {
        // Row 1: shift right by 1
        let t1 = state[13];
        state[13] = state[9]; state[9] = state[5]; state[5] = state[1]; state[1] = t1;
        // Row 2: shift right by 2
        let t2a = state[2]; let t2b = state[6];
        state[2] = state[10]; state[6] = state[14]; state[10] = t2a; state[14] = t2b;
        // Row 3: shift right by 3 (= shift left by 1)
        let t3 = state[3];
        state[3] = state[7]; state[7] = state[11]; state[11] = state[15]; state[15] = t3;
    }

    func AesMixColumns(state: *uint8) {
        var col: uint32 = 0u32;
        while col < 4u32 {
            let b = col * 4u32;
            let s0 = state[b];
            let s1 = state[b + 1u32];
            let s2 = state[b + 2u32];
            let s3 = state[b + 3u32];
            state[b]        = AesMul(0x02u8, s0) ^ AesMul(0x03u8, s1) ^ s2 ^ s3;
            state[b + 1u32] = s0 ^ AesMul(0x02u8, s1) ^ AesMul(0x03u8, s2) ^ s3;
            state[b + 2u32] = s0 ^ s1 ^ AesMul(0x02u8, s2) ^ AesMul(0x03u8, s3);
            state[b + 3u32] = AesMul(0x03u8, s0) ^ s1 ^ s2 ^ AesMul(0x02u8, s3);
            col = col + 1u32;
        }
    }

    func AesMixColumnsInv(state: *uint8) {
        var col: uint32 = 0u32;
        while col < 4u32 {
            let b = col * 4u32;
            let s0 = state[b];
            let s1 = state[b + 1u32];
            let s2 = state[b + 2u32];
            let s3 = state[b + 3u32];
            state[b]        = AesMul(0x0eu8, s0) ^ AesMul(0x0bu8, s1) ^ AesMul(0x0du8, s2) ^ AesMul(0x09u8, s3);
            state[b + 1u32] = AesMul(0x09u8, s0) ^ AesMul(0x0eu8, s1) ^ AesMul(0x0bu8, s2) ^ AesMul(0x0du8, s3);
            state[b + 2u32] = AesMul(0x0du8, s0) ^ AesMul(0x09u8, s1) ^ AesMul(0x0eu8, s2) ^ AesMul(0x0bu8, s3);
            state[b + 3u32] = AesMul(0x0bu8, s0) ^ AesMul(0x0du8, s1) ^ AesMul(0x09u8, s2) ^ AesMul(0x0eu8, s3);
            col = col + 1u32;
        }
    }

    func AesEncryptBlock(ctx: *AesContext, input: *const uint8, output: *uint8) {
        var state: uint8[16];
        var i: uint32 = 0u32;
        while i < 16u32 {
            state[i] = input[i];
            i = i + 1u32;
        }

        AesAddRoundKey(&state[0], &ctx.roundKeys[0]);

        var round: uint32 = 1u32;
        while round < ctx.rounds {
            AesSubBytes(&state[0]);
            AesShiftRows(&state[0]);
            AesMixColumns(&state[0]);
            AesAddRoundKey(&state[0], &ctx.roundKeys[round * 16u32]);
            round = round + 1u32;
        }

        // Final round — no MixColumns
        AesSubBytes(&state[0]);
        AesShiftRows(&state[0]);
        AesAddRoundKey(&state[0], &ctx.roundKeys[ctx.rounds * 16u32]);

        i = 0u32;
        while i < 16u32 {
            output[i] = state[i];
            i = i + 1u32;
        }
    }

    func AesDecryptBlock(ctx: *AesContext, input: *const uint8, output: *uint8) {
        var state: uint8[16];
        var i: uint32 = 0u32;
        while i < 16u32 {
            state[i] = input[i];
            i = i + 1u32;
        }

        AesAddRoundKey(&state[0], &ctx.roundKeys[ctx.rounds * 16u32]);

        var round: uint32 = ctx.rounds - 1u32;
        while round > 0u32 {
            AesShiftRowsInv(&state[0]);
            AesSubBytesInv(&state[0]);
            AesAddRoundKey(&state[0], &ctx.roundKeys[round * 16u32]);
            AesMixColumnsInv(&state[0]);
            round = round - 1u32;
        }

        // Final round
        AesShiftRowsInv(&state[0]);
        AesSubBytesInv(&state[0]);
        AesAddRoundKey(&state[0], &ctx.roundKeys[0]);

        i = 0u32;
        while i < 16u32 {
            output[i] = state[i];
            i = i + 1u32;
        }
    }


    // Public API


    /// Initialises an AesContext for encryption with a 128 or 256-bit key
    /// keyBits must be 128 or 256
    pub func AesInitEncrypt(ctx: *AesContext, key: *const uint8, keyBits: uint32) {
        AesExpandKey(ctx, key, keyBits);
    }

    /// Initialises an AesContext for decryption with a 128 or 256-bit key
    /// keyBits must be 128 or 256
    pub func AesInitDecrypt(ctx: *AesContext, key: *const uint8, keyBits: uint32) {
        AesExpandKey(ctx, key, keyBits);
    }

    /// Encrypts a single 16-byte block in ECB mode
    pub func AesEcbEncrypt(ctx: *AesContext, input: *const uint8, output: *uint8) {
        AesEncryptBlock(ctx, input, output);
    }

    /// Decrypts a single 16-byte block in ECB mode
    pub func AesEcbDecrypt(ctx: *AesContext, input: *const uint8, output: *uint8) {
        AesDecryptBlock(ctx, input, output);
    }

    /// Encrypts len bytes in CBC mode
    /// len must be a multiple of 16; iv is consumed (mutated) block by block
    pub func AesCbcEncrypt(ctx: *AesContext, iv: *uint8, input: *const uint8, output: *uint8, len: uint32) {
        var offset: uint32 = 0u32;
        while offset < len {
            // XOR plaintext block with IV (or previous ciphertext block)
            var block: uint8[16];
            var i: uint32 = 0u32;
            while i < 16u32 {
                block[i] = input[offset + i] ^ iv[i];
                i = i + 1u32;
            }
            AesEncryptBlock(ctx, &block[0], &output[offset]);
            // Update IV to current ciphertext block
            i = 0u32;
            while i < 16u32 {
                iv[i] = output[offset + i];
                i = i + 1u32;
            }
            offset = offset + 16u32;
        }
    }

    /// Decrypts len bytes in CBC mode
    /// len must be a multiple of 16; iv is consumed (mutated) block by block
    pub func AesCbcDecrypt(ctx: *AesContext, iv: *uint8, input: *const uint8, output: *uint8, len: uint32) {
        var offset: uint32 = 0u32;
        while offset < len {
            var block: uint8[16];
            AesDecryptBlock(ctx, &input[offset], &block[0]);
            // XOR with IV to recover plaintext
            var i: uint32 = 0u32;
            while i < 16u32 {
                output[offset + i] = block[i] ^ iv[i];
                i = i + 1u32;
            }
            // Update IV to current ciphertext block
            i = 0u32;
            while i < 16u32 {
                iv[i] = input[offset + i];
                i = i + 1u32;
            }
            offset = offset + 16u32;
        }
    }
}
